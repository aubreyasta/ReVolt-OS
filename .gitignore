# =============================================================================
# ReVolt OS -- .gitignore (frontend branch)
# Server code lives on main/backend. This branch is frontend only.
# =============================================================================

# ---- Server -- entire directory excluded ----
server/

# ---- Node ----
node_modules/
client/node_modules/

# ---- Vite build output ----
client/dist/
client/dist-ssr/

# ---- Local env files ----
.env
.env.*
!.env.example

# ---- Python (in case of accidental adds) ----
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/
.venv/
venv/

# ---- OS junk ----
.DS_Store
Thumbs.db

# ---- Editor ----
.vscode/*
!.vscode/extensions.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# ---- Logs ----
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ---- Misc ----
*.local
